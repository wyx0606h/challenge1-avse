# Optional local/runtime variables.
#
# This repository does not automatically load .env files. Export variables
# explicitly or use the server/job scheduler's secret mechanism.
# Never put real credentials in this example file.

# Standard Hugging Face authentication. Prefer `huggingface-cli login` or a
# scheduler secret when possible.
HF_TOKEN=

# Optional Hugging Face mirror or custom endpoint.
HF_ENDPOINT=

# Conda environment used by install/evaluation scripts.
ENV_NAME=real-avse

# TODO: absolute external path after challenge data access is confirmed.
DATA_ROOT=

# External output directory for enhanced audio/submission files.
SAVE_DIR=

# Optional precomputed speaker-enrollment checkpoint.
ENROLL_CKPT=

# Optional Hugging Face repo ID or local checkpoint path.
CKPT=

# GPU selection used by the smoke script.
GPU=0

# Python executable used by the Track 2 smoke script.
PYTHON=python

# Python executable used by download_models.sh.
PY=python
